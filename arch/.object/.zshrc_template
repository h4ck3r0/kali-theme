# ~/.zshrc file for Arch Linux - Customized by H4CK3R

# Basic Shell Options
setopt autocd              # Change directory just by typing its name
setopt interactivecomments # Allow comments in interactive shell
setopt promptsubst         # Enable substitution in prompt
setopt notify              # Report background job status immediately

# History Configuration
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt hist_ignore_dups    # Ignore duplicates in history
setopt hist_ignore_space   # Ignore commands starting with space

# Key Bindings (Emacs style)
bindkey -e
bindkey '^[[H' beginning-of-line
bindkey '^[[F' end-of-line
bindkey '^[[3~' delete-char

# Set Shell Name for the Prompt
export SHELL_NAME="PROC"

# Oh-My-Zsh Integration
if [ -d "$HOME/.oh-my-zsh" ]; then
    export ZSH="$HOME/.oh-my-zsh"
    ZSH_THEME="h4Ck3r_arch"
    plugins=(git)
    source $ZSH/oh-my-zsh.sh
else
    # Standalone prompt and theme loading
    if [ -f "$HOME/.zsh/themes/h4Ck3r_arch.zsh-theme" ]; then
        source "$HOME/.zsh/themes/h4Ck3r_arch.zsh-theme"
    else
        PROMPT='%F{cyan}%n@%m %F{blue}%~ %F{yellow}❯ %f'
    fi
fi

# Load Syntax Highlighting and Autosuggestions
# Arch path for system plugins:
# /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
# /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

if [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
elif [ -f "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    source "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

if [ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
    ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#666'
elif [ -f "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"
    ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#666'
fi

# Aliases
alias ls='ls --color=auto'
alias la='ls -A'
alias ll='ls -lh'
alias grep='grep --color=auto'
alias pacupd='sudo pacman -Syu'
alias pacinst='sudo pacman -S'
alias pacrem='sudo pacman -Rns'

# Interactive Thumbnail / Fastfetch Banner
if [ -x "$(command -v fastfetch)" ]; then
    if [ -f "$HOME/.config/fastfetch/config.jsonc" ]; then
        fastfetch --config "$HOME/.config/fastfetch/config.jsonc"
    else
        fastfetch
    fi
else
    # Simple ASCII Art fallback if fastfetch is missing
    echo -e "\e[1;36m  /\  \e[0m"
    echo -e "\e[1;36m /  \ \e[1;37m  Arch Linux\e[0m"
    echo -e "\e[1;36m/ _ _ \ \e[0m"
fi
